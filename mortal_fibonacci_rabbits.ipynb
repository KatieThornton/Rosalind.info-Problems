   "source": [
    "def rabbit_pairs(n,m):\n",
    "    ages = [1] + [0] * (m-1)\n",
    "\n",
    "    for i in range (2, n+1):\n",
    "        new_borns = sum(ages[1:])\n",
    "        ages = [new_borns] + ages[0:m-1]\n",
    "        ages[0] = new_borns\n",
    "\n",
    "    print (sum(ages))\n",
    "\n",
    "rabbit_pairs(6,3)"
   ]
  }
 ],
