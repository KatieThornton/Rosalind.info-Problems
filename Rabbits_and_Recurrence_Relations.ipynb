   "source": [
    "def rabbit_pairs(n, k):\n",
    "    if n == 1 or n==2:\n",
    "        return 1\n",
    "    f = [0] * (n+1)\n",
    "    f[1] = 1\n",
    "    f[2] = 1\n",
    "    for i in range (3, n+1):\n",
    "        f[i] = f[i-1] + (k*f[i-2])\n",
    "    return f[n]\n",
    "print(rabbit_pairs(34,4))\n"
   ]
  },
